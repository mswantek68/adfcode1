{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "df-swantekplay"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"swantekgeneralblob_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'swantekgeneralblob'"
		},
		"targetcosmosdb_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'targetcosmosdb'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://swantekdlsynapse.dfs.core.windows.net"
		},
		"NutritionJson_sasUri": {
			"type": "secureString",
			"metadata": "Secure string for 'sasUri' of 'NutritionJson'"
		},
		"PlatedataOakland_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://data.oaklandca.gov/resource/wy2w-ue82.json"
		},
		"WeatherDataRest_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://api.weather.gov/gridpoints/DTX/60,40/forecast/hourly"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "df-swantekplay_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2018-02-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"swantekgeneralblob_connectionString": {
						"value": "[parameters('swantekgeneralblob_connectionString')]"
					},
					"targetcosmosdb_connectionString": {
						"value": "[parameters('targetcosmosdb_connectionString')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"NutritionJson_sasUri": {
						"value": "[parameters('NutritionJson_sasUri')]"
					},
					"PlatedataOakland_properties_typeProperties_url": {
						"value": "[parameters('PlatedataOakland_properties_typeProperties_url')]"
					},
					"WeatherDataRest_properties_typeProperties_url": {
						"value": "[parameters('WeatherDataRest_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "df-swantekplay_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2018-02-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'df-swantekplay_ArmTemplate_0')]"
			]
		}
	]
}