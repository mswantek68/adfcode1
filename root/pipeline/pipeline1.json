{
	"name": "pipeline1",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "7.00:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings",
							"copyBehavior": "FlattenHierarchy"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".csv"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"path": "$['type']"
								},
								"sink": {
									"name": "type"
								}
							},
							{
								"source": {
									"path": "$['properties']['hash']"
								},
								"sink": {
									"name": "hash"
								}
							},
							{
								"source": {
									"path": "$['properties']['number']"
								},
								"sink": {
									"name": "number"
								}
							},
							{
								"source": {
									"path": "$['properties']['street']"
								},
								"sink": {
									"name": "street"
								}
							},
							{
								"source": {
									"path": "$['properties']['unit']"
								},
								"sink": {
									"name": "unit"
								}
							},
							{
								"source": {
									"path": "$['properties']['city']"
								},
								"sink": {
									"name": "city"
								}
							},
							{
								"source": {
									"path": "$['properties']['district']"
								},
								"sink": {
									"name": "district"
								}
							},
							{
								"source": {
									"path": "$['properties']['region']"
								},
								"sink": {
									"name": "region"
								}
							},
							{
								"source": {
									"path": "$['properties']['postcode']"
								},
								"sink": {
									"name": "postcode"
								}
							},
							{
								"source": {
									"path": "$['properties']['id']"
								},
								"sink": {
									"name": "id"
								}
							},
							{
								"source": {
									"path": "$['geometry']['coordinates'][0]"
								},
								"sink": {
									"name": "longitude"
								}
							},
							{
								"source": {
									"path": "$['geometry']['coordinates'][1]"
								},
								"sink": {
									"name": "latitude"
								}
							}
						],
						"collectionReference": "$['geometry']['coordinates']",
						"mapComplexValuesToString": false
					}
				},
				"inputs": [
					{
						"referenceName": "OaklandCountyAddresses",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "OCAddressCSV",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": [],
		"lastPublishTime": "2021-06-16T18:46:11Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}